{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentContractReviewOutput",
  "description": "Output schema for the Senior Legal Contract Reviewer Agent v2.0 benchmark cases, with ORCHESTRATOR report generation support.",
  "type": "object",
  "properties": {
    "risk_level": {
      "type": "string",
      "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW", "SAFE"],
      "description": "Overall risk severity of the analyzed clause."
    },
    "identified_vulnerability": {
      "type": "string",
      "description": "Detailed explanation of the hidden legal or commercial trap."
    },
    "clause_location": {
      "type": "string",
      "description": "The exact clause text or location reference from the contract that triggers this vulnerability."
    },
    "expected_loss_estimation": {
      "type": "object",
      "properties": {
        "amount_range": {
          "type": "string",
          "description": "Estimated financial exposure range (e.g., '100W - 200W RMB')."
        },
        "calculation_logic": {
          "type": "string",
          "description": "Logic for calculating EL, including judicial adjustment rules (e.g. 130% rule)."
        }
      },
      "required": ["amount_range", "calculation_logic"]
    },
    "legal_citations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "law_name": { "type": "string" },
          "article_number": { "type": "string" }
        },
        "required": ["law_name"]
      },
      "description": "Specific laws or regulations cited as defense basis."
    },
    "citation_verified": {
      "type": "boolean",
      "description": "MUST BE TRUE if the citation was actively verified via RAG/Internet. FALSE if hallucinated or purely from LLM memory."
    },
    "confidence_degrade": {
      "type": "string",
      "description": "If citation_verified is false, explicitly state the memory-degradation warning."
    },
    "defense_plan_b": {
      "type": "string",
      "description": "The mandatory, unyielding replacement clause (Plan B) to protect the user's interests."
    },
    "agent_findings": {
      "type": "array",
      "description": "Per-agent risk findings collected by ORCHESTRATOR for report generation.",
      "items": {
        "type": "object",
        "properties": {
          "agent_name": {
            "type": "string",
            "description": "Agent identifier, e.g. 'Agent-1 合规审核'"
          },
          "agent_role": {
            "type": "string",
            "description": "Agent role description"
          },
          "quality_scores": {
            "type": "object",
            "description": "ORCHESTRATOR quality audit scores for this agent",
            "properties": {
              "citation_accuracy": { "type": "number", "minimum": 0, "maximum": 25 },
              "coverage_completeness": { "type": "number", "minimum": 0, "maximum": 25 },
              "logical_consistency": { "type": "number", "minimum": 0, "maximum": 25 },
              "actionability": { "type": "number", "minimum": 0, "maximum": 25 }
            }
          },
          "risk_items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "risk_id": { "type": "string" },
                "risk_tag": { "type": "string" },
                "severity": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"] },
                "clause_location": { "type": "string" },
                "finding": { "type": "string" },
                "legal_basis": { "type": "string" },
                "recommendation": { "type": "string" }
              },
              "required": ["risk_tag", "severity", "finding", "recommendation"]
            }
          }
        },
        "required": ["agent_name", "agent_role", "risk_items"]
      }
    },
    "risk_scores": {
      "type": "object",
      "description": "Five-dimensional risk scoring by ORCHESTRATOR",
      "properties": {
        "compliance_risk": { "type": "number", "minimum": 0, "maximum": 100 },
        "financial_risk": { "type": "number", "minimum": 0, "maximum": 100 },
        "adversarial_risk": { "type": "number", "minimum": 0, "maximum": 100 },
        "performance_risk": { "type": "number", "minimum": 0, "maximum": 100 },
        "commercial_risk": { "type": "number", "minimum": 0, "maximum": 100 },
        "composite_index": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "final_modification_suggestions": {
      "type": "array",
      "description": "Prioritized clause-level modification suggestions.",
      "items": {
        "type": "object",
        "properties": {
          "priority": { "type": "integer" },
          "clause_ref": { "type": "string" },
          "current_text": { "type": "string" },
          "suggested_text": { "type": "string" },
          "rationale": { "type": "string" },
          "legal_basis": { "type": "string" }
        },
        "required": ["priority", "clause_ref", "suggested_text", "rationale"]
      }
    }
  },
  "required": [
    "risk_level",
    "identified_vulnerability",
    "clause_location",
    "expected_loss_estimation",
    "legal_citations",
    "citation_verified",
    "defense_plan_b"
  ]
}